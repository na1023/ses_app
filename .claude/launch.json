{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "SES業務管理 (Streamlit)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "streamlit", "run", "app.py", "--server.port", "8501"],
      "port": 8501
